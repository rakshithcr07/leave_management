<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified">
    <Dialog id="idCreateDialog" title="Submit Leave Request">
        <content>
            <form:SimpleForm id="idSimpleFormFragment" editable="true" layout="ResponsiveGridLayout">
                <Label text="Type" required="true" />
                <Select id="idTypeSelect" items="{/LeaveTypes}" change=".onLeaveTypeChange">
                    <core:Item key="{ID}" text="{name}" />
                </Select>
                
                <Label text="Start Date" required="true" />
                <DatePicker id="idStart" change=".onDateChange" />
                
                <Label text="End Date" required="true" />
                <DatePicker id="idEnd" change=".onDateChange" />

                <Label text="Total Days" />
                <Input id="idTotalDays" editable="false" value="0" width="100px" />

                <Label id="idLabelAttachment" text="Medical Certificate" visible="false" required="true" />
                <u:FileUploader id="idFileUploader" visible="false" placeholder="Upload certificate..." />
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="Submit" type="Emphasized" press=".onSaveRequest" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>